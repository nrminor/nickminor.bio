---
import { siteConfig } from "../consts.ts";

const year = new Date().getFullYear();

const navLinks = [
  { text: "Home", slug: "", route: "/" },
  { text: "About", slug: "about", route: "/about" },
  { text: "Blog", slug: "blog", route: "/blog/pages/1" },
  { text: "Projects", slug: "projects", route: "/projects/pages/1" },
  { text: "Archive", slug: "archive", route: "/archive" },
];
---

<footer
  class="mt-auto flex w-full flex-col items-center justify-center gap-y-2 pb-4 pt-20 text-center align-top font-semibold sm:flex-row sm:justify-between sm:text-xs text-[var(--theme-text)] mb-8"
>
  <div class="mr-2 sm:mr-0">
    Copyright &copy; {year}{" "}
    {siteConfig.profile.author}
  </div>
  <nav
    aria-label="More on this site"
    class="sm:flex sm:divide-x sm:divide-accent"
  >
    {
      navLinks.map((link) => (
        <a
          href={link.route}
          class="px-2 py-0 hover:text-[var(--theme-text)] hover:underline sm:px-4 sm:py-1 text-center"
        >
          {link.text}
        </a>
      ))
    }
  </nav>
</footer>
