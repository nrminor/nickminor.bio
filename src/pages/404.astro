---
import BaseLayout from "../layouts/Base.astro";
---

<BaseLayout title="404">
  <section
    class="flex justify-center items-center h-80 border-dashed border border-[var(--theme-accent)]"
  >
    <div class="flex-col gap-2 text-8xl p-4 h-min">
      <span id="status-code"> 404</span>
      <div
        class="border-b-2 border-[var(--theme-accent)] w-full border-solid blink mt-1"
      >
      </div>
    </div>
    <span>Looks like you're lost! You sure you know where you're going?</span>
  </section>
</BaseLayout>

<style>
  @reference "tailwindcss";
  #status-code:before {
    content: "./";
    @apply text-[var(--theme-accent-2)] hover:text-[var(--theme-accent)];
  }

  .blink {
    animation: blink-animation 1.5s steps(2, start) infinite;
    -webkit-animation: blink-animation 1.5s steps(2, start) infinite;
  }

  @keyframes blink-animation {
    to {
      visibility: hidden;
    }
  }

  @-webkit-keyframes blink-animation {
    to {
      visibility: hidden;
    }
  }
</style>
