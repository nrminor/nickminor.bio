{
  "name": "nickminor-bio",
  "type": "module",
  "version": "1.3.5",
  "engines": {
    "bun": ">=1.2.0",
    "npm": ">=10.9.0",
    "node": ">=23.11.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "bunx prettier --write \"**/*.astro\" && bunx biome format --write .",
    "format:astro": "bunx prettier --write \"**/*.astro\"",
    "format:ts": "bunx biome format --write .",
    "lint": "bunx biome lint --write .",
    "check": "bunx biome check . && bunx prettier --check \"**/*.astro\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.5",
    "@astrojs/mdx": "^4.3.9",
    "@astrojs/rss": "^4.0.13",
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/solid-js": "^5.1.3",
    "@observablehq/plot": "^0.6.17",
    "@tailwindcss/vite": "^4.1.16",
    "astro": "^5.15.3",
    "astro-icon": "^1.1.5",
    "d3": "^7.9.0",
    "mdast-util-to-string": "^4.0.0",
    "reading-time": "^1.5.0",
    "solid-js": "^1.9.10",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "zdog": "^1.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@iconify-json/carbon": "^1.2.14",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/vscode-icons": "^1.2.33",
    "@mdx-js/language-server": "^0.6.3",
    "@tailwindcss/typography": "^0.5.19",
    "@types/zdog": "^1.1.7",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-language-server": "^5.1.3"
  }
}
