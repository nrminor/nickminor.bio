{
  "name": "nickminor-bio",
  "type": "module",
  "version": "1.3.5",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "bunx prettier --write \"**/*.astro\" && bunx biome format --write .",
    "format:astro": "bunx prettier --write \"**/*.astro\"",
    "format:ts": "bunx biome format --write .",
    "lint": "bunx biome lint --write .",
    "check": "bunx biome check . && bunx prettier --check \"**/*.astro\""
  },
  "dependencies": {
    "@astrojs/check": "^0.5.10",
    "@astrojs/mdx": "^2.3.1",
    "@astrojs/rss": "^4.0.5",
    "@astrojs/sitemap": "^3.1.4",
    "@astrojs/tailwind": "^5.1.0",
    "astro": "^4.6.3",
    "astro-icon": "^0.8.2",
    "d3": "^7.9.0",
    "echarts": "^5.6.0",
    "mdast-util-to-string": "^4.0.0",
    "nodejs-polars": "^0.18.0",
    "reading-time": "^1.5.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "zdog": "^1.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@tailwindcss/typography": "^0.5.10",
    "prettier": "^3.3.0",
    "prettier-plugin-astro": "^0.14.1"
  }
}
